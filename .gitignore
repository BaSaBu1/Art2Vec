# Python cache files - auto-generated, not needed for running the code
__pycache__/
*.pyc
*.pyo
.venv/

# Root-level npm files are not part of the project app; website deps live in website_v2/
/node_modules/
/package.json
/package-lock.json

# Raw source dataset - too large to share (223 MB) and not needed if you
# already have the processed data_clean/ files
/raw_data_eda/
/data_clean/
/data/

# Analysis outputs generated from the data; keep the scripts, not these artifacts
/motif/
/color/
/embedding/
/color_analysis/results/

# Gephi visualization project files - kept locally for reference but not
# needed to reproduce the analysis
gephi/

# Local planning/prototype/reference files not needed for public code release
context.md
decisions.md
Art2Vec.html
art2vec-app.jsx
NotablePaintings.md
phase2_report.md
paper/
website/

# Website build artifacts - generated by `npm run build`, not source code
website/node_modules/
website/dist/
website_v2/node_modules/
website_v2/dist/

# Development log files
website/dev-server.log
website/dev-server.err.log
website_v2/dev-server.log
website_v2/dev-server.err.log
